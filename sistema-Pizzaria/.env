# Define a porta em que o servidor Express irá rodar.
# Se você mudar para 4000, o site passará a ser acessado em localhost:4000.
PORT=3001

# Define o local e o nome do arquivo do banco de dados SQLite.
# O SQLite não precisa de um servidor externo, ele salva tudo nesse arquivo .db.
DB_PATH=./pizzaria.db

# Esta é a "Chave Mestra" do seu sistema. 
# Ela é usada pelo código de Autenticação (JWT) que vimos antes para 
# assinar os tokens dos usuários. 
# IMPORTANTE: Em um sistema real, essa senha deve ser muito longa e complexa.
JWT_SECRET=senha123456